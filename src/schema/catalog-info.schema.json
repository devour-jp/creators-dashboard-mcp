{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/devour-jp/creators-dashboard-mcp/main/src/schema/catalog-info.schema.json",
  "title": "catalog-info.yaml",
  "description": "Creators Dashboard catalog-info.yaml schema",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata"],
  "properties": {
    "apiVersion": {
      "const": "devour.jp/v1alpha1"
    },
    "kind": {
      "const": "Component"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "$ref": "#/definitions/textPair"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 10
        },
        "links": {
          "$ref": "#/definitions/links"
        }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["website", "service", "library", "game", "tool", "docs"]
        },
        "lifecycle": {
          "enum": ["experimental", "production", "deprecated", "archived"]
        },
        "owner": {
          "type": "string"
        },
        "devour": {
          "$ref": "#/definitions/devour"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "textPair": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "short": { "type": "string" },
            "long": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "title": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "maxItems": 12
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$"
    },
    "release": {
      "type": "object",
      "properties": {
        "current": {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "headline": { "$ref": "#/definitions/textPair" }
          },
          "additionalProperties": false
        },
        "next": {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "headline": { "$ref": "#/definitions/textPair" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "author": {
      "type": "object",
      "properties": {
        "comment": { "$ref": "#/definitions/textPair" }
      },
      "additionalProperties": false
    },
    "card": {
      "type": "object",
      "properties": {
        "bg": { "$ref": "#/definitions/hexColor" },
        "fg": { "$ref": "#/definitions/hexColor" }
      },
      "additionalProperties": false
    },
    "socialX": {
      "type": "object",
      "properties": {
        "account": { "type": "string" },
        "fix": { "type": "string", "pattern": "^\\d+$" },
        "latest": {
          "type": "object",
          "properties": {
            "query": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "social": {
      "type": "object",
      "properties": {
        "x": { "$ref": "#/definitions/socialX" }
      },
      "additionalProperties": false
    },
    "org": {
      "type": "object",
      "properties": {
        "bio": { "$ref": "#/definitions/textPair" },
        "links": { "$ref": "#/definitions/links" },
        "social": { "$ref": "#/definitions/social" }
      },
      "additionalProperties": false
    },
    "devour": {
      "type": "object",
      "properties": {
        "release": { "$ref": "#/definitions/release" },
        "author": { "$ref": "#/definitions/author" },
        "card": { "$ref": "#/definitions/card" },
        "social": { "$ref": "#/definitions/social" },
        "org": { "$ref": "#/definitions/org" }
      },
      "additionalProperties": false
    }
  }
}
